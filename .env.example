# Satori Engine environment variables

# API key for SDK integration tests (sdk/test-integration.mjs)
SATORI_API_KEY=your-api-key-here

# Cloudflare R2 lifecycle script (scripts/configure-r2-lifecycle.sh)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
